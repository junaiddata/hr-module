# ─── Copy this file to .env and fill in your values ───────────────────────────

# ── LOCAL DEVELOPMENT (SQLite) ─────────────────────────────────────────────────
DEBUG=True
USE_SQLITE=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,hr.junaidworld.com

# ── PRODUCTION SERVER (PostgreSQL) ────────────────────────────────────────────
# Uncomment and fill in the lines below on your server.
# Also change DEBUG and USE_SQLITE above.
#
# DEBUG=False
# USE_SQLITE=False
# SECRET_KEY=a-long-random-secret-key-for-production
# ALLOWED_HOSTS=hr.junaidworld.com
#
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_HOST=localhost
# DB_PORT=5432
