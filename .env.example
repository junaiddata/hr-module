# ─── Copy this file to .env and fill in your values ───────────────────────────

# ── LOCAL DEVELOPMENT (SQLite) ─────────────────────────────────────────────────
DEBUG=True
USE_SQLITE=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,hr.junaidworld.com

# ── PRODUCTION SERVER (PostgreSQL) ────────────────────────────────────────────
# Uncomment and fill in the lines below on your server.
# Also change DEBUG and USE_SQLITE above.
#
# DEBUG=False
# USE_SQLITE=False
# SECRET_KEY=a-long-random-secret-key-for-production
# ALLOWED_HOSTS=hr.junaidworld.com
#
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_HOST=localhost
# DB_PORT=5432

# ── WHATSAPP CLOUD API (Meta) — birthday wishes ───────────────────────────────
# Get these from Meta: developers.facebook.com > your app > WhatsApp > API Setup.
# Leave blank to keep the feature off (buttons hidden, daily command no-ops).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version (bump if Meta deprecates it).
WHATSAPP_API_VERSION=v21.0
# The APPROVED template name + its language code, exactly as in Meta.
WHATSAPP_BIRTHDAY_TEMPLATE=birthday_wish
WHATSAPP_BIRTHDAY_TEMPLATE_LANG=en
# Set False if your template has NO {{1}} variable; True passes the first name.
WHATSAPP_BIRTHDAY_NAME_PARAM=True
# Country code prepended to local numbers (UAE = 971).
WHATSAPP_DEFAULT_COUNTRY_CODE=971
